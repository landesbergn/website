---
const agentId = import.meta.env.PUBLIC_ELEVENLABS_AGENT_ID;
---

{agentId && (
  <section class="talk-to-me" aria-label="Voice chat with Noah">
    <button id="ttm-btn" type="button" data-state="idle">
      <svg
        class="asterisk"
        viewBox="-10 -10 20 20"
        width="14"
        height="14"
        aria-hidden="true"
        focusable="false"
      >
        <g stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <line x1="0" y1="-8.5" x2="0" y2="8.5" />
          <line x1="-7.36" y1="-4.25" x2="7.36" y2="4.25" />
          <line x1="-7.36" y1="4.25" x2="7.36" y2="-4.25" />
        </g>
      </svg>
      <span class="label">Talk to me</span>
    </button>
    <p class="disclosure">Heads up, you will be recorded.</p>
    <p id="ttm-status" class="status" hidden></p>
  </section>
)}

<script>
  import { Conversation } from "@elevenlabs/client";

  const agentId = import.meta.env.PUBLIC_ELEVENLABS_AGENT_ID;
  if (agentId) {
    const btn = document.getElementById("ttm-btn") as HTMLButtonElement | null;
    const label = btn?.querySelector(".label") as HTMLSpanElement | null;
    const statusEl = document.getElementById("ttm-status") as HTMLParagraphElement | null;

    type SessionRef = { current: Awaited<ReturnType<typeof Conversation.startSession>> | null };
    const session: SessionRef = { current: null };

    function setState(state: "idle" | "connecting" | "listening" | "speaking" | "ending", text: string) {
      if (btn) btn.dataset.state = state;
      if (label) label.textContent = text;
    }

    function setStatus(text: string | null) {
      if (!statusEl) return;
      if (!text) {
        statusEl.hidden = true;
        statusEl.textContent = "";
      } else {
        statusEl.textContent = text;
        statusEl.hidden = false;
      }
    }

    async function start() {
      setState("connecting", "Connecting…");
      setStatus(null);
      try {
        session.current = await Conversation.startSession({
          agentId,
          onConnect: () => setState("listening", "End conversation"),
          onDisconnect: () => {
            session.current = null;
            setState("idle", "Talk to me");
          },
          onError: (err: unknown) => {
            console.error("ElevenLabs error:", err);
            const msg = err instanceof Error ? err.message : String(err);
            setStatus(`Couldn't connect: ${msg}`);
            session.current = null;
            setState("idle", "Talk to me");
          },
          onModeChange: ({ mode }: { mode: "speaking" | "listening" }) => {
            setState(mode, "End conversation");
          },
        });
      } catch (err: unknown) {
        console.error("Start failed:", err);
        const msg = err instanceof Error ? err.message : String(err);
        setStatus(`Couldn't connect: ${msg}`);
        setState("idle", "Talk to me");
      }
    }

    async function stop() {
      setState("ending", "Ending…");
      try {
        await session.current?.endSession();
      } catch (err) {
        console.error("End failed:", err);
      }
      session.current = null;
      setState("idle", "Talk to me");
    }

    btn?.addEventListener("click", () => {
      if (session.current) stop();
      else start();
    });

    window.addEventListener("beforeunload", () => {
      session.current?.endSession().catch(() => {});
    });
  }
</script>

<style>
  .talk-to-me {
    margin: 2rem 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule, #e5e0d4);
  }

  #ttm-btn {
    font-family: inherit;
    font-size: 1rem;
    background: transparent;
    color: #1c1c1c;
    border: 1px solid #1c1c1c;
    padding: 0.55rem 1.1rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    transition: color 120ms ease, border-color 120ms ease;
  }

  #ttm-btn:hover {
    color: #b14545;
    border-color: #b14545;
  }

  #ttm-btn:disabled {
    cursor: progress;
    opacity: 0.7;
  }

  .asterisk {
    display: inline-block;
    color: #b14545;
    flex-shrink: 0;
    transform-origin: 50% 50%;
    transition: color 200ms ease;
    overflow: visible;
  }

  /* state: idle — static asterisk */
  #ttm-btn[data-state="idle"] .asterisk {
    color: #b14545;
  }

  /* state: connecting — gentle fade */
  #ttm-btn[data-state="connecting"] .asterisk {
    color: #c69a3f;
    animation: ttm-fade 1s ease-in-out infinite;
  }

  /* state: listening — slow rotation */
  #ttm-btn[data-state="listening"] .asterisk {
    color: #5a8a55;
    animation: ttm-spin 4s linear infinite;
  }

  /* state: speaking — fast rotation */
  #ttm-btn[data-state="speaking"] .asterisk {
    color: #b14545;
    animation: ttm-spin 1.1s linear infinite;
  }

  /* state: ending — grey, frozen */
  #ttm-btn[data-state="ending"] .asterisk {
    color: #6b6b6b;
  }

  @keyframes ttm-spin {
    to { transform: rotate(360deg); }
  }
  @keyframes ttm-fade {
    0%, 100% { opacity: 1;   }
    50%      { opacity: 0.35; }
  }

  @media (prefers-reduced-motion: reduce) {
    .asterisk { animation: none !important; }
  }

  .disclosure {
    font-size: 14px;
    color: #6b6b6b;
    margin-top: 0.6rem;
    max-width: 56ch;
  }

  .status {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
    color: #b14545;
    margin-top: 0.6rem;
  }
</style>
