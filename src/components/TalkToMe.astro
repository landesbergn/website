---
const agentId = import.meta.env.PUBLIC_ELEVENLABS_AGENT_ID;
---

{agentId && (
  <section class="talk-to-me" aria-label="Voice chat with Noah">
    <button id="ttm-btn" type="button" data-state="idle">
      <span class="bars" aria-hidden="true">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </span>
      <span class="label">Talk to me</span>
    </button>
    <p class="disclosure">Heads up, you will be recorded.</p>
    <p id="ttm-status" class="status" hidden></p>
  </section>
)}

<script>
  import { Conversation } from "@elevenlabs/client";

  const agentId = import.meta.env.PUBLIC_ELEVENLABS_AGENT_ID;
  if (agentId) {
    const btn = document.getElementById("ttm-btn") as HTMLButtonElement | null;
    const label = btn?.querySelector(".label") as HTMLSpanElement | null;
    const statusEl = document.getElementById("ttm-status") as HTMLParagraphElement | null;

    type SessionRef = { current: Awaited<ReturnType<typeof Conversation.startSession>> | null };
    const session: SessionRef = { current: null };

    function setState(state: "idle" | "connecting" | "listening" | "speaking" | "ending", text: string) {
      if (btn) btn.dataset.state = state;
      if (label) label.textContent = text;
    }

    function setStatus(text: string | null) {
      if (!statusEl) return;
      if (!text) {
        statusEl.hidden = true;
        statusEl.textContent = "";
      } else {
        statusEl.textContent = text;
        statusEl.hidden = false;
      }
    }

    async function start() {
      setState("connecting", "Connecting…");
      setStatus(null);
      try {
        session.current = await Conversation.startSession({
          agentId,
          onConnect: () => setState("listening", "End conversation"),
          onDisconnect: () => {
            session.current = null;
            setState("idle", "Talk to me");
          },
          onError: (err: unknown) => {
            console.error("ElevenLabs error:", err);
            const msg = err instanceof Error ? err.message : String(err);
            setStatus(`Couldn't connect: ${msg}`);
            session.current = null;
            setState("idle", "Talk to me");
          },
          onModeChange: ({ mode }: { mode: "speaking" | "listening" }) => {
            setState(mode, "End conversation");
          },
        });
      } catch (err: unknown) {
        console.error("Start failed:", err);
        const msg = err instanceof Error ? err.message : String(err);
        setStatus(`Couldn't connect: ${msg}`);
        setState("idle", "Talk to me");
      }
    }

    async function stop() {
      setState("ending", "Ending…");
      try {
        await session.current?.endSession();
      } catch (err) {
        console.error("End failed:", err);
      }
      session.current = null;
      setState("idle", "Talk to me");
    }

    btn?.addEventListener("click", () => {
      if (session.current) stop();
      else start();
    });

    window.addEventListener("beforeunload", () => {
      session.current?.endSession().catch(() => {});
    });
  }
</script>

<style>
  .talk-to-me {
    margin: 2rem 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule, #e5e0d4);
  }

  #ttm-btn {
    font-family: inherit;
    font-size: 1rem;
    background: transparent;
    color: #1c1c1c;
    border: 1px solid #1c1c1c;
    padding: 0.55rem 1.1rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    transition: color 120ms ease, border-color 120ms ease;
  }

  #ttm-btn:hover {
    color: #b14545;
    border-color: #b14545;
  }

  #ttm-btn:disabled {
    cursor: progress;
    opacity: 0.7;
  }

  .bars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    height: 14px;
    flex-shrink: 0;
  }

  .bar {
    display: inline-block;
    width: 3px;
    height: 14px;
    background: #b14545;
    transform-origin: center;
    transform: scaleY(0.3);
    transition: background 200ms ease;
  }

  /* state: idle — short static bars */
  #ttm-btn[data-state="idle"] .bar {
    transform: scaleY(0.3);
  }

  /* state: connecting — soft synchronized pulse */
  #ttm-btn[data-state="connecting"] .bar {
    background: #c69a3f;
    animation: ttm-pulse 1s ease-in-out infinite;
  }

  /* state: listening — synchronized wave */
  #ttm-btn[data-state="listening"] .bar {
    background: #5a8a55;
    animation: ttm-wave 1.3s ease-in-out infinite;
  }
  #ttm-btn[data-state="listening"] .bar:nth-child(1) { animation-delay: 0s; }
  #ttm-btn[data-state="listening"] .bar:nth-child(2) { animation-delay: 0.18s; }
  #ttm-btn[data-state="listening"] .bar:nth-child(3) { animation-delay: 0.36s; }

  /* state: speaking — bars dance independently like an EQ */
  #ttm-btn[data-state="speaking"] .bar {
    background: #b14545;
  }
  #ttm-btn[data-state="speaking"] .bar:nth-child(1) {
    animation: ttm-dance-a 0.6s ease-in-out infinite;
  }
  #ttm-btn[data-state="speaking"] .bar:nth-child(2) {
    animation: ttm-dance-b 0.45s ease-in-out infinite;
  }
  #ttm-btn[data-state="speaking"] .bar:nth-child(3) {
    animation: ttm-dance-c 0.75s ease-in-out infinite;
  }

  /* state: ending — fade to grey */
  #ttm-btn[data-state="ending"] .bar {
    background: #6b6b6b;
    transform: scaleY(0.3);
  }

  @keyframes ttm-pulse {
    0%, 100% { transform: scaleY(0.35); opacity: 1; }
    50%      { transform: scaleY(0.6);  opacity: 0.5; }
  }

  @keyframes ttm-wave {
    0%, 100% { transform: scaleY(0.3); }
    50%      { transform: scaleY(0.85); }
  }

  @keyframes ttm-dance-a {
    0%, 100% { transform: scaleY(0.3); }
    50%      { transform: scaleY(1);   }
  }
  @keyframes ttm-dance-b {
    0%, 100% { transform: scaleY(0.5); }
    30%      { transform: scaleY(0.2); }
    70%      { transform: scaleY(0.95); }
  }
  @keyframes ttm-dance-c {
    0%, 100% { transform: scaleY(0.4); }
    40%      { transform: scaleY(1);   }
    80%      { transform: scaleY(0.6); }
  }

  @media (prefers-reduced-motion: reduce) {
    .bar {
      animation: none !important;
      transform: scaleY(0.5);
    }
  }

  .disclosure {
    font-size: 14px;
    color: #6b6b6b;
    margin-top: 0.6rem;
    max-width: 56ch;
  }

  .status {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
    color: #b14545;
    margin-top: 0.6rem;
  }
</style>
