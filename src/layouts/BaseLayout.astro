---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Noah Landesberg's personal site." } = Astro.props;
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || (pathname.startsWith(href) && href !== '/');

const buildDate = new Date().toISOString().slice(0, 10);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/image/favicon.png" />
    <link rel="canonical" href={new URL(pathname, Astro.site).toString()} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <h1 class="site-title"><a href="/">Noah Landesberg</a></h1>
        <nav>
          <a href="/" aria-current={pathname === '/' ? 'page' : undefined}>home</a>
          <span class="sep">·</span>
          <a href="/projects/" aria-current={isActive('/projects/') ? 'page' : undefined}>projects</a>
          <span class="sep">·</span>
          <a href="/blog/" aria-current={isActive('/blog/') ? 'page' : undefined}>blog</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>
          email: noah.landesberg [at] gmail.com
          &nbsp;·&nbsp;
          <a href="https://github.com/landesbergn">github</a>
          &nbsp;·&nbsp;
          <a href="https://www.linkedin.com/in/noah-landesberg">linkedin</a>
        </p>
        <p>hand-coded HTML, mostly. last updated {buildDate}.</p>
      </footer>
    </div>

    <script>
      // PostHog cookieless init — no consent banner needed.
      // persistence: 'memory' = each visit is a new identity, no cookies/localStorage.
      import posthog from 'posthog-js';
      const key = import.meta.env.PUBLIC_POSTHOG_KEY;
      if (key) {
        posthog.init(key, {
          api_host: 'https://us.i.posthog.com',
          persistence: 'memory',           // cookieless — no consent banner needed
          capture_pageview: true,          // track pageviews
          autocapture: true,               // track clicks, form submits, link clicks
          capture_exceptions: true,        // track unhandled JS errors
          disable_session_recording: false // session replay (enable in PostHog UI)
        });
      }
    </script>
  </body>
</html>
