---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Talk-to-me logs" description="Private review page for talk-to-me conversations.">
  <h1>Talk-to-me logs</h1>

  <div id="gate">
    <p>Enter the admin key to view conversations.</p>
    <input id="key-input" type="password" placeholder="admin key" autocomplete="off" />
    <button id="load-btn">Load</button>
    <p id="error" class="error" hidden></p>
  </div>

  <div id="content" hidden>
    <p id="count" class="meta"></p>
    <ul id="list"></ul>
    <article id="detail" hidden></article>
  </div>
</BaseLayout>

<script>
  type Turn = { role: "user" | "noah"; ts: number; text: string };
  type Conv = {
    conversation_id: string;
    started_at: string;
    duration_s: number;
    transcript: Turn[];
    ended_by: string;
  };

  const $ = (id: string) => document.getElementById(id)!;
  const gate = $("gate");
  const content = $("content");
  const error = $("error") as HTMLParagraphElement;
  const list = $("list") as HTMLUListElement;
  const detail = $("detail") as HTMLElement;
  const count = $("count") as HTMLParagraphElement;
  const keyInput = $("key-input") as HTMLInputElement;

  let cache: Conv[] = [];

  async function load(key: string) {
    error.hidden = true;
    const res = await fetch(`/api/list-conversations?key=${encodeURIComponent(key)}`);
    if (!res.ok) {
      error.textContent = res.status === 401 ? "wrong key" : `error: ${res.status}`;
      error.hidden = false;
      return;
    }
    const data = (await res.json()) as { conversations: Conv[] };
    cache = data.conversations;
    sessionStorage.setItem("talk-to-me-key", key);
    render();
  }

  function render() {
    gate.hidden = true;
    content.hidden = false;
    count.textContent = `${cache.length} conversation${cache.length === 1 ? "" : "s"}`;
    list.innerHTML = "";
    for (const c of cache) {
      const li = document.createElement("li");
      const firstUser = c.transcript.find((t) => t.role === "user")?.text ?? "(no user turn)";
      li.innerHTML = `
        <button class="row" data-id="${c.conversation_id}">
          <span class="row-date">${c.started_at.slice(0, 16).replace("T", " ")}</span>
          <span class="row-dur">${Math.round(c.duration_s)}s</span>
          <span class="row-preview">${firstUser.slice(0, 80)}</span>
        </button>
      `;
      list.appendChild(li);
    }
    list.querySelectorAll<HTMLButtonElement>(".row").forEach((b) =>
      b.addEventListener("click", () => show(b.dataset.id!))
    );
  }

  function show(id: string) {
    const c = cache.find((x) => x.conversation_id === id);
    if (!c) return;
    detail.hidden = false;
    detail.innerHTML = `
      <h2>${c.started_at}</h2>
      <p class="meta">${Math.round(c.duration_s)}s · ended by ${c.ended_by}</p>
      ${c.transcript
        .map(
          (t) => `<p class="turn ${t.role}"><strong>${t.role}:</strong> ${escapeHtml(t.text)}</p>`
        )
        .join("")}
    `;
    detail.scrollIntoView({ behavior: "smooth" });
  }

  function escapeHtml(s: string) {
    return s.replace(
      /[&<>"']/g,
      (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!
    );
  }

  $("load-btn").addEventListener("click", () => load(keyInput.value));
  keyInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") load(keyInput.value);
  });

  const remembered = sessionStorage.getItem("talk-to-me-key");
  if (remembered) load(remembered);
</script>

<style>
  .meta { font-family: ui-monospace, monospace; color: #6b6b6b; font-size: 14px; }
  .error { color: #b14545; font-family: ui-monospace, monospace; font-size: 14px; }
  #list { list-style: none; padding: 0; }
  .row {
    display: grid;
    grid-template-columns: 140px 60px 1fr;
    gap: 1rem;
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    border-bottom: 1px solid #e5e0d4;
    padding: 0.5rem 0;
    cursor: pointer;
    font: inherit;
    color: inherit;
  }
  .row:hover { background: #f7f0db; }
  .row-date, .row-dur { font-family: ui-monospace, monospace; font-size: 13px; color: #6b6b6b; }
  .row-preview { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .turn { margin: 0.5rem 0; }
  .turn.noah strong { color: #b14545; }
</style>
