---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Talk-to-me icons" description="Internal icon-comparison page.">
  <h1>Icon options</h1>
  <p>
    Each button auto-cycles through idle → listening → speaking
    (~2s each) so you can see the animations rendered. Tell me which one
    you want as the live treatment and I'll wire it up and remove this page.
  </p>

  <ol class="opts">
    <li>
      <h3>1 — Microphone (line art)</h3>
      <button class="ttm-btn" data-icon="mic" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 16 18" width="14" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <rect class="mic-body" x="6" y="2" width="4" height="8" rx="2" />
            <path d="M4 9 a4 4 0 0 0 8 0" />
            <line x1="8" y1="13" x2="8" y2="15" />
            <line x1="5.5" y1="15" x2="10.5" y2="15" />
            <g class="mic-wave">
              <path d="M12 6 q 1.5 2 0 4" />
              <path d="M14 4 q 2.5 4 0 8" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>2 — Broadcast arcs (sonar)</h3>
      <button class="ttm-btn" data-icon="arcs" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <circle cx="3" cy="8" r="1.2" fill="currentColor" stroke="none" />
            <path class="arc arc-1" d="M5.5 5.5 A 3.5 3.5 0 0 1 5.5 10.5" />
            <path class="arc arc-2" d="M8.5 3 A 6 6 0 0 1 8.5 13" />
            <path class="arc arc-3" d="M11.5 0.5 A 8.5 8.5 0 0 1 11.5 15.5" />
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>3 — Speech bubble</h3>
      <button class="ttm-btn" data-icon="bubble" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round">
            <path class="bubble-body" d="M1.5 3 a1.5 1.5 0 0 1 1.5 -1.5 h 10 a1.5 1.5 0 0 1 1.5 1.5 v 6 a1.5 1.5 0 0 1 -1.5 1.5 h -5 l -3.5 3 v -3 h -1.5 a1.5 1.5 0 0 1 -1.5 -1.5 z" />
            <g class="bubble-dots">
              <circle cx="5" cy="6" r="0.7" fill="currentColor" stroke="none" />
              <circle cx="8" cy="6" r="0.7" fill="currentColor" stroke="none" />
              <circle cx="11" cy="6" r="0.7" fill="currentColor" stroke="none" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>4 — Pulsing dot with rings</h3>
      <button class="ttm-btn" data-icon="rings" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="-10 -10 20 20" width="16" height="16" overflow="visible">
            <circle class="ring ring-3" r="9" fill="none" stroke="currentColor" stroke-width="1" />
            <circle class="ring ring-2" r="6" fill="none" stroke="currentColor" stroke-width="1" />
            <circle r="2.5" fill="currentColor" />
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>5 — Concentric chevrons (waveform)</h3>
      <button class="ttm-btn" data-icon="chev" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 18 14" width="18" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path class="chev chev-1" d="M3 5 L 7 7 L 3 9" />
            <path class="chev chev-2" d="M8 3 L 13 7 L 8 11" />
            <path class="chev chev-3" d="M14 1 L 18 7 L 14 13" />
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>6 — Animated ellipsis (typing dots)</h3>
      <button class="ttm-btn" data-icon="dots" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 18 6" width="18" height="8" fill="currentColor">
            <circle class="d d-1" cx="3" cy="3" r="1.6" />
            <circle class="d d-2" cx="9" cy="3" r="1.6" />
            <circle class="d d-3" cx="15" cy="3" r="1.6" />
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>
  </ol>
</BaseLayout>

<script>
  type S = "idle" | "listening" | "speaking";
  const cycle: { state: S; label: string }[] = [
    { state: "idle",      label: "Talk to me" },
    { state: "listening", label: "I'm listening" },
    { state: "speaking",  label: "Thinking…" },
  ];

  const buttons = document.querySelectorAll<HTMLButtonElement>(".ttm-btn");
  let i = 0;
  function tick() {
    const c = cycle[i];
    buttons.forEach((b) => {
      b.dataset.state = c.state;
      const lbl = b.querySelector(".label");
      if (lbl) lbl.textContent = c.label;
    });
    i = (i + 1) % cycle.length;
  }
  tick();
  setInterval(tick, 2200);
</script>

<style>
  .opts { list-style: none; padding: 0; }
  .opts li { margin: 1.6rem 0; }
  .opts h3 { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 13px; color: #6b6b6b; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 0.5rem; }

  .ttm-btn {
    font-family: inherit;
    font-size: 1rem;
    background: transparent;
    color: #1c1c1c;
    border: 1px solid #1c1c1c;
    padding: 0.55rem 1.1rem;
    cursor: default;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .icon { display: inline-flex; align-items: center; color: #b14545; flex-shrink: 0; }

  /* Per-state color reused across icons */
  .ttm-btn[data-state="listening"] .icon { color: #5a8a55; }
  .ttm-btn[data-state="speaking"]  .icon { color: #b14545; }

  /* ── 1. Microphone ──────────────────────────────── */
  .ttm-btn[data-icon="mic"] .mic-body { fill: transparent; transition: fill 200ms ease; }
  .ttm-btn[data-icon="mic"][data-state="listening"] .mic-body { fill: currentColor; }
  .ttm-btn[data-icon="mic"][data-state="speaking"]  .mic-body { fill: currentColor; }
  .ttm-btn[data-icon="mic"] .mic-wave { opacity: 0; }
  .ttm-btn[data-icon="mic"][data-state="speaking"] .mic-wave { opacity: 1; animation: pulse 0.6s ease-in-out infinite; }

  /* ── 2. Broadcast arcs ──────────────────────────── */
  .ttm-btn[data-icon="arcs"] .arc { opacity: 0.25; }
  .ttm-btn[data-icon="arcs"][data-state="idle"] .arc-1 { opacity: 1; }
  .ttm-btn[data-icon="arcs"][data-state="listening"] .arc-1,
  .ttm-btn[data-icon="arcs"][data-state="listening"] .arc-2,
  .ttm-btn[data-icon="arcs"][data-state="listening"] .arc-3 {
    animation: sonar 1.4s ease-in-out infinite;
  }
  .ttm-btn[data-icon="arcs"][data-state="listening"] .arc-2 { animation-delay: 0.2s; }
  .ttm-btn[data-icon="arcs"][data-state="listening"] .arc-3 { animation-delay: 0.4s; }
  .ttm-btn[data-icon="arcs"][data-state="speaking"] .arc { animation: sonar 0.7s ease-in-out infinite; }
  .ttm-btn[data-icon="arcs"][data-state="speaking"] .arc-2 { animation-delay: 0.1s; }
  .ttm-btn[data-icon="arcs"][data-state="speaking"] .arc-3 { animation-delay: 0.2s; }
  @keyframes sonar {
    0%, 100% { opacity: 0.2; }
    50%      { opacity: 1; }
  }

  /* ── 3. Speech bubble ───────────────────────────── */
  .ttm-btn[data-icon="bubble"] .bubble-body { fill: transparent; transition: fill 200ms ease; }
  .ttm-btn[data-icon="bubble"][data-state="listening"] .bubble-body { fill: currentColor; fill-opacity: 0.15; }
  .ttm-btn[data-icon="bubble"][data-state="speaking"]  .bubble-body { fill: currentColor; fill-opacity: 0.15; }
  .ttm-btn[data-icon="bubble"] .bubble-dots { opacity: 0; }
  .ttm-btn[data-icon="bubble"][data-state="speaking"] .bubble-dots { opacity: 1; }
  .ttm-btn[data-icon="bubble"][data-state="speaking"] .bubble-dots circle:nth-child(1) { animation: blink 1s ease-in-out infinite; }
  .ttm-btn[data-icon="bubble"][data-state="speaking"] .bubble-dots circle:nth-child(2) { animation: blink 1s ease-in-out infinite 0.2s; }
  .ttm-btn[data-icon="bubble"][data-state="speaking"] .bubble-dots circle:nth-child(3) { animation: blink 1s ease-in-out infinite 0.4s; }
  @keyframes blink {
    0%, 100% { opacity: 0.3; }
    50%      { opacity: 1;   }
  }

  /* ── 4. Pulsing dot + rings ─────────────────────── */
  .ttm-btn[data-icon="rings"] .ring { opacity: 0; }
  .ttm-btn[data-icon="rings"][data-state="listening"] .ring-2,
  .ttm-btn[data-icon="rings"][data-state="listening"] .ring-3 {
    animation: ringpulse 1.6s ease-out infinite;
    opacity: 1;
  }
  .ttm-btn[data-icon="rings"][data-state="listening"] .ring-3 { animation-delay: 0.4s; }
  .ttm-btn[data-icon="rings"][data-state="speaking"] .ring-2,
  .ttm-btn[data-icon="rings"][data-state="speaking"] .ring-3 {
    animation: ringpulse 0.8s ease-out infinite;
    opacity: 1;
  }
  .ttm-btn[data-icon="rings"][data-state="speaking"] .ring-3 { animation-delay: 0.2s; }
  @keyframes ringpulse {
    0%   { transform: scale(0.4); opacity: 0.9; }
    100% { transform: scale(1.2); opacity: 0;   }
  }

  /* ── 5. Concentric chevrons ─────────────────────── */
  .ttm-btn[data-icon="chev"] .chev { opacity: 0.3; }
  .ttm-btn[data-icon="chev"][data-state="idle"] .chev-1 { opacity: 1; }
  .ttm-btn[data-icon="chev"][data-state="listening"] .chev {
    animation: chevpulse 1.4s ease-in-out infinite;
  }
  .ttm-btn[data-icon="chev"][data-state="listening"] .chev-2 { animation-delay: 0.2s; }
  .ttm-btn[data-icon="chev"][data-state="listening"] .chev-3 { animation-delay: 0.4s; }
  .ttm-btn[data-icon="chev"][data-state="speaking"] .chev { animation: chevpulse 0.7s ease-in-out infinite; }
  .ttm-btn[data-icon="chev"][data-state="speaking"] .chev-2 { animation-delay: 0.1s; }
  .ttm-btn[data-icon="chev"][data-state="speaking"] .chev-3 { animation-delay: 0.2s; }
  @keyframes chevpulse {
    0%, 100% { opacity: 0.2; }
    50%      { opacity: 1;   }
  }

  /* ── 6. Animated ellipsis ──────────────────────── */
  .ttm-btn[data-icon="dots"] .d { opacity: 0.4; }
  .ttm-btn[data-icon="dots"][data-state="listening"] .d,
  .ttm-btn[data-icon="dots"][data-state="speaking"]  .d {
    animation: pulse 1.2s ease-in-out infinite;
  }
  .ttm-btn[data-icon="dots"][data-state="listening"] .d-2,
  .ttm-btn[data-icon="dots"][data-state="speaking"]  .d-2 { animation-delay: 0.2s; }
  .ttm-btn[data-icon="dots"][data-state="listening"] .d-3,
  .ttm-btn[data-icon="dots"][data-state="speaking"]  .d-3 { animation-delay: 0.4s; }
  .ttm-btn[data-icon="dots"][data-state="speaking"] .d { animation-duration: 0.6s; }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50%      { opacity: 1;   }
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation-duration: 0s !important; }
  }
</style>
