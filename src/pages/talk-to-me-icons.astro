---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Talk-to-me icons (v2)" description="Internal icon-comparison page.">
  <h1>Icon options — round 2</h1>
  <p>
    Each button auto-cycles: idle → listening → speaking (~2.2s each).
    These are deliberately more visually divergent. Pick a number.
  </p>

  <ol class="opts">
    <li>
      <h3>1 — Rotary phone handset</h3>
      <button class="ttm-btn" data-icon="phone" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="-10 -10 20 20" width="18" height="18" overflow="visible">
            <g class="phone-body" fill="currentColor">
              <path d="M -7 -1 Q -7 -4 -4 -4 L -4 0 Q -4 1 -5 1 Q -7 1 -7 -1 Z" />
              <path d="M  7 -1 Q  7 -4  4 -4 L  4 0 Q  4 1  5 1 Q  7 1  7 -1 Z" />
              <rect x="-5" y="-1" width="10" height="2.4" />
            </g>
            <g class="phone-waves" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
              <path class="pw pw-1" d="M -9 -6 Q -7 -8 -5 -6" />
              <path class="pw pw-2" d="M  9 -6 Q  7 -8  5 -6" />
              <path class="pw pw-3" d="M -10 -8 Q -7 -11 -4 -8" />
              <path class="pw pw-4" d="M  10 -8 Q  7 -11  4 -8" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>2 — Cassette tape (reels spin)</h3>
      <button class="ttm-btn" data-icon="cassette" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 22 14" width="22" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
            <rect x="1" y="1" width="20" height="12" rx="1.5" />
            <g class="reel reel-l" transform-origin="6 7" transform="translate(6 7)">
              <circle r="2.6" />
              <line x1="0" y1="-1.6" x2="0" y2="1.6" stroke-width="0.8" />
              <line x1="-1.6" y1="0" x2="1.6" y2="0" stroke-width="0.8" />
            </g>
            <g class="reel reel-r" transform-origin="16 7" transform="translate(16 7)">
              <circle r="2.6" />
              <line x1="0" y1="-1.6" x2="0" y2="1.6" stroke-width="0.8" />
              <line x1="-1.6" y1="0" x2="1.6" y2="0" stroke-width="0.8" />
            </g>
            <line x1="9" y1="7" x2="13" y2="7" stroke-width="0.7" />
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>3 — Tuning fork</h3>
      <button class="ttm-btn" data-icon="fork" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="-10 -10 20 20" width="18" height="18" overflow="visible" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
            <line class="fork-tine fork-l" x1="-3" y1="-9" x2="-3" y2="1" />
            <line class="fork-tine fork-r" x1=" 3" y1="-9" x2=" 3" y2="1" />
            <path d="M -3 1 Q 0 4 3 1 L 3 4 Q 0 5.5 -3 4 Z" fill="currentColor" stroke="none" />
            <line x1="0" y1="5" x2="0" y2="9" />
            <g class="fork-vibe" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
              <path class="fv fv-1" d="M -6 -7 Q -7 -5 -6 -3" />
              <path class="fv fv-1" d="M  6 -7 Q  7 -5  6 -3" />
              <path class="fv fv-2" d="M -8 -8 Q -10 -5 -8 -2" />
              <path class="fv fv-2" d="M  8 -8 Q  10 -5  8 -2" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>4 — Vinyl record</h3>
      <button class="ttm-btn" data-icon="vinyl" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="-10 -10 20 20" width="18" height="18">
            <g class="vinyl-body">
              <circle r="9" fill="currentColor" />
              <circle r="6.5" fill="none" stroke="#fdfbf5" stroke-width="0.35" opacity="0.5" />
              <circle r="5" fill="none" stroke="#fdfbf5" stroke-width="0.35" opacity="0.5" />
              <circle r="3.5" fill="none" stroke="#fdfbf5" stroke-width="0.35" opacity="0.5" />
              <circle r="2.2" fill="#fdfbf5" />
              <circle r="0.6" fill="currentColor" />
              <line x1="-1" y1="-9.2" x2="-1" y2="-8" stroke="#fdfbf5" stroke-width="0.6" opacity="0.4" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>5 — Megaphone</h3>
      <button class="ttm-btn" data-icon="mega" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 22 18" width="22" height="18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round">
            <path d="M2 8 L 2 10 L 6 11 L 14 14 L 14 4 L 6 7 Z" fill="currentColor" />
            <line x1="6" y1="7" x2="6" y2="11" stroke="#fdfbf5" stroke-width="0.8" />
            <line x1="9" y1="14" x2="10" y2="17" />
            <g class="mega-waves">
              <path class="mw mw-1" d="M 16 7 Q 18 9 16 11" />
              <path class="mw mw-2" d="M 19 5 Q 22 9 19 13" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>6 — Quotation marks (typographic)</h3>
      <button class="ttm-btn" data-icon="quote" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 22 14" width="22" height="14">
            <g class="quote-l" fill="currentColor">
              <path d="M2 9 Q 2 4 6 3 L 6 5 Q 4 5.5 4.5 7 L 6 7 L 6 11 L 2 11 Z" />
            </g>
            <g class="quote-r" fill="currentColor">
              <path d="M20 5 Q 20 10 16 11 L 16 9 Q 18 8.5 17.5 7 L 16 7 L 16 3 L 20 3 Z" />
            </g>
            <g class="quote-dots" fill="currentColor">
              <circle class="qd" cx="9" cy="7" r="1" />
              <circle class="qd" cx="11" cy="7" r="1" />
              <circle class="qd" cx="13" cy="7" r="1" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>7 — Old radio dial</h3>
      <button class="ttm-btn" data-icon="dial" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="-10 -10 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
            <circle r="8.5" />
            <line x1="0" y1="-8.5" x2="0" y2="-6.5" />
            <line x1="0" y1=" 8.5" x2="0" y2=" 6.5" />
            <line x1="-8.5" y1="0" x2="-6.5" y2="0" />
            <line x1=" 8.5" y1="0" x2=" 6.5" y2="0" />
            <g class="dial-needle" transform-origin="0 0">
              <line x1="0" y1="0" x2="0" y2="-6" stroke-width="1.6" />
              <circle r="1.2" fill="currentColor" stroke="none" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>

    <li>
      <h3>8 — Ear (literal listening)</h3>
      <button class="ttm-btn" data-icon="ear" data-state="idle" type="button">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 16 18" width="16" height="18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round">
            <path d="M3 8 a5 5 0 0 1 10 0 c0 2 -1.5 3 -2.5 3.5 c -1.5 0.7 -1 2 -2 3 a2.2 2.2 0 0 1 -3.5 -1.2 c0 -1 1 -2 1 -3 c0 -1 -3 -1 -3 -2.3 Z" />
            <path d="M6 8 a2 2 0 0 1 4 0" />
            <g class="ear-waves">
              <path class="ew ew-1" d="M15 7 Q 17 9 15 11" stroke-linecap="round" />
              <path class="ew ew-2" d="M18 5 Q 21 9 18 13" stroke-linecap="round" />
            </g>
          </svg>
        </span>
        <span class="label">Talk to me</span>
      </button>
    </li>
  </ol>
</BaseLayout>

<script>
  type S = "idle" | "listening" | "speaking";
  const cycle: { state: S; label: string }[] = [
    { state: "idle",      label: "Talk to me" },
    { state: "listening", label: "I'm listening" },
    { state: "speaking",  label: "Thinking…" },
  ];
  const buttons = document.querySelectorAll<HTMLButtonElement>(".ttm-btn");
  let i = 0;
  function tick() {
    const c = cycle[i];
    buttons.forEach((b) => {
      b.dataset.state = c.state;
      const lbl = b.querySelector(".label");
      if (lbl) lbl.textContent = c.label;
    });
    i = (i + 1) % cycle.length;
  }
  tick();
  setInterval(tick, 2200);
</script>

<style>
  .opts { list-style: none; padding: 0; }
  .opts li { margin: 1.6rem 0; }
  .opts h3 { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 13px; color: #6b6b6b; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 0.5rem; }

  .ttm-btn {
    font-family: inherit;
    font-size: 1rem;
    background: transparent;
    color: #1c1c1c;
    border: 1px solid #1c1c1c;
    padding: 0.55rem 1.1rem;
    cursor: default;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .icon { display: inline-flex; align-items: center; color: #b14545; flex-shrink: 0; line-height: 0; }
  .ttm-btn[data-state="listening"] .icon { color: #5a8a55; }
  .ttm-btn[data-state="speaking"]  .icon { color: #b14545; }

  /* ── 1. Rotary phone ───────────────────────────── */
  .ttm-btn[data-icon="phone"] .pw { opacity: 0; }
  .ttm-btn[data-icon="phone"] .phone-body {
    transform-origin: 0 0;
    transition: transform 300ms ease;
  }
  .ttm-btn[data-icon="phone"][data-state="listening"] .phone-body { transform: rotate(-15deg); }
  .ttm-btn[data-icon="phone"][data-state="listening"] .pw-1,
  .ttm-btn[data-icon="phone"][data-state="listening"] .pw-2 {
    opacity: 1; animation: fadewave 1.3s ease-in-out infinite;
  }
  .ttm-btn[data-icon="phone"][data-state="speaking"] .phone-body { transform: rotate(-15deg); }
  .ttm-btn[data-icon="phone"][data-state="speaking"] .pw { opacity: 1; animation: fadewave 0.7s ease-in-out infinite; }
  .ttm-btn[data-icon="phone"][data-state="speaking"] .pw-3,
  .ttm-btn[data-icon="phone"][data-state="speaking"] .pw-4 { animation-delay: 0.15s; }

  /* ── 2. Cassette ───────────────────────────────── */
  .ttm-btn[data-icon="cassette"] .reel { transform-box: fill-box; }
  .ttm-btn[data-icon="cassette"][data-state="listening"] .reel-l,
  .ttm-btn[data-icon="cassette"][data-state="listening"] .reel-r {
    animation: spin 3s linear infinite;
  }
  .ttm-btn[data-icon="cassette"][data-state="speaking"] .reel-l,
  .ttm-btn[data-icon="cassette"][data-state="speaking"] .reel-r {
    animation: spin 0.9s linear infinite;
  }

  /* ── 3. Tuning fork ────────────────────────────── */
  .ttm-btn[data-icon="fork"] .fork-tine { transform-origin: 50% 100%; }
  .ttm-btn[data-icon="fork"] .fork-vibe { opacity: 0; }
  .ttm-btn[data-icon="fork"][data-state="listening"] .fork-l { animation: wobble-l 0.6s ease-in-out infinite; }
  .ttm-btn[data-icon="fork"][data-state="listening"] .fork-r { animation: wobble-r 0.6s ease-in-out infinite; }
  .ttm-btn[data-icon="fork"][data-state="listening"] .fork-vibe { opacity: 1; animation: fadewave 0.6s ease-in-out infinite; }
  .ttm-btn[data-icon="fork"][data-state="speaking"] .fork-l { animation: wobble-l 0.25s ease-in-out infinite; }
  .ttm-btn[data-icon="fork"][data-state="speaking"] .fork-r { animation: wobble-r 0.25s ease-in-out infinite; }
  .ttm-btn[data-icon="fork"][data-state="speaking"] .fork-vibe { opacity: 1; animation: fadewave 0.25s ease-in-out infinite; }

  @keyframes wobble-l {
    0%, 100% { transform: rotate(-3deg); }
    50%      { transform: rotate( 3deg); }
  }
  @keyframes wobble-r {
    0%, 100% { transform: rotate( 3deg); }
    50%      { transform: rotate(-3deg); }
  }

  /* ── 4. Vinyl ──────────────────────────────────── */
  .ttm-btn[data-icon="vinyl"] .vinyl-body { transform-origin: 50% 50%; transform-box: fill-box; }
  .ttm-btn[data-icon="vinyl"][data-state="listening"] .vinyl-body { animation: spin 4s linear infinite; }
  .ttm-btn[data-icon="vinyl"][data-state="speaking"]  .vinyl-body { animation: spin 1.5s linear infinite; }

  /* ── 5. Megaphone ──────────────────────────────── */
  .ttm-btn[data-icon="mega"] .mw { opacity: 0; }
  .ttm-btn[data-icon="mega"][data-state="listening"] .mw-1 { opacity: 0.5; }
  .ttm-btn[data-icon="mega"][data-state="speaking"] .mw { opacity: 1; animation: fadewave 0.5s ease-in-out infinite; }
  .ttm-btn[data-icon="mega"][data-state="speaking"] .mw-2 { animation-delay: 0.15s; }

  /* ── 6. Quote marks ────────────────────────────── */
  .ttm-btn[data-icon="quote"] .quote-dots { opacity: 0; }
  .ttm-btn[data-icon="quote"][data-state="speaking"] .quote-dots { opacity: 1; }
  .ttm-btn[data-icon="quote"][data-state="speaking"] .qd:nth-child(1) { animation: blink 1s ease-in-out infinite;     }
  .ttm-btn[data-icon="quote"][data-state="speaking"] .qd:nth-child(2) { animation: blink 1s ease-in-out infinite 0.2s; }
  .ttm-btn[data-icon="quote"][data-state="speaking"] .qd:nth-child(3) { animation: blink 1s ease-in-out infinite 0.4s; }
  .ttm-btn[data-icon="quote"][data-state="listening"] .quote-l,
  .ttm-btn[data-icon="quote"][data-state="listening"] .quote-r {
    animation: pulse 1.4s ease-in-out infinite;
  }

  /* ── 7. Radio dial ─────────────────────────────── */
  .ttm-btn[data-icon="dial"] .dial-needle { transform-origin: 50% 50%; transform-box: fill-box; }
  .ttm-btn[data-icon="dial"][data-state="listening"] .dial-needle { animation: needle-slow 2s ease-in-out infinite; }
  .ttm-btn[data-icon="dial"][data-state="speaking"]  .dial-needle { animation: needle-fast 0.6s ease-in-out infinite; }
  @keyframes needle-slow {
    0%, 100% { transform: rotate(-30deg); }
    50%      { transform: rotate( 30deg); }
  }
  @keyframes needle-fast {
    0%, 100% { transform: rotate(-60deg); }
    50%      { transform: rotate( 60deg); }
  }

  /* ── 8. Ear ────────────────────────────────────── */
  .ttm-btn[data-icon="ear"] .ew { opacity: 0; }
  .ttm-btn[data-icon="ear"][data-state="listening"] .ew-1 { opacity: 1; animation: fadewave 1.4s ease-in-out infinite; }
  .ttm-btn[data-icon="ear"][data-state="listening"] .ew-2 { opacity: 0.6; animation: fadewave 1.4s ease-in-out infinite 0.2s; }
  .ttm-btn[data-icon="ear"][data-state="speaking"]  .ew { opacity: 1; animation: fadewave 0.5s ease-in-out infinite; }
  .ttm-btn[data-icon="ear"][data-state="speaking"]  .ew-2 { animation-delay: 0.15s; }

  /* ── shared keyframes ──────────────────────────── */
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  @keyframes fadewave {
    0%, 100% { opacity: 0.25; }
    50%      { opacity: 1;    }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1;   }
    50%      { opacity: 0.45;}
  }
  @keyframes blink {
    0%, 100% { opacity: 0.3; }
    50%      { opacity: 1;   }
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation-duration: 0s !important; }
  }
</style>
