---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const collectionPosts = await getCollection('blog', ({ data }) => !data.draft);
const frozenPosts = [
  { title: 'Web scraping Reply All transcripts', date: new Date('2019-02-02'), url: '/blog/post/web-scraping-reply-all-transcripts/' },
  { title: 'Introducing rhymer', date: new Date('2017-12-23'), url: '/blog/post/introducing-rhymer/' },
  { title: 'Thinking in Systems with DiagrammeR', date: new Date('2017-10-17'), url: '/blog/post/thinking-in-systems-with-diagrammer/' },
];

const recent = [
  ...collectionPosts.map((p) => ({ title: p.data.title, date: p.data.date, url: `/blog/${p.data.permalink}/` })),
  ...frozenPosts,
]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 4);

const iso = (d: Date) => d.toISOString().slice(0, 10);
---

<BaseLayout title="Noah Landesberg" description="Personal site of Noah Landesberg, a product leader working at the intersection of healthcare and AI.">
  <p>
    Bay Area-based product leader working at the intersection of healthcare and
    AI. Most recently I was Head of Product at <a href="https://www.getfreed.ai">Freed</a>,
    and before that I built products at <a href="https://www.helloalma.com">Alma</a>,
    <a href="https://www.hioscar.com">Oscar Health</a>, and
    <a href="https://www.athenahealth.com">athenahealth</a>.
  </p>

  <p>
    In my spare time I build software that's mostly useless, like an
    <a href="https://landesbergn.github.io/rhymer/index.html">R package for finding rhyming words</a>
    or an iOS weather app that tells you what it
    <a href="https://github.com/landesbergn/feels-like">"feels like"</a> outside.
  </p>

  <p class="divider-ascii">───●───</p>

  <h2>recent writing</h2>
  <ul class="post-list">
    {recent.map((post) => (
      <li>
        <time datetime={iso(post.date)}>{iso(post.date)}</time>
        <a href={post.url}>{post.title}</a>
      </li>
    ))}
  </ul>
  <p class="back-link"><a href="/blog/">all posts →</a></p>
</BaseLayout>
